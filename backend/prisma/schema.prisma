generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  UPCOMING
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String
  displayName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model Task {
  id        String    @id @default(cuid())
  title     String
  dueDate   DateTime?
  status    Status    @default(UPCOMING)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}